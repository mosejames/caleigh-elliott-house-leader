rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Pledges counter - anyone can read, anyone can update (increment)
    match /pledges/counter {
      allow read: if true;
      allow write: if true;
    }

    // Pledge submissions
    match /pledges/submissions/entries/{entry} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'timestamp'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 30;
      // Admin moderation — allow delete from the /admin panel
      allow delete: if true;
    }

    // Shoutouts - anyone can read and create; admin can moderate
    match /shoutouts/{shoutout} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'timestamp'])
                    && request.resource.data.name is string
                    && request.resource.data.message is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.message.size() <= 140;
      allow delete: if true;
    }

    // Photos metadata - anyone can read and create; admin can moderate
    match /photos/{photo} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'storageUrl', 'timestamp'])
                    && request.resource.data.name is string
                    && request.resource.data.storageUrl is string;
      allow delete: if true;
    }

    // Questions - anyone can read answered, anyone can create
    match /questions/{question} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'question', 'answer', 'status', 'timestamp'])
                    && request.resource.data.status == 'unanswered';
      // Admin updates (answer questions) - allow update only to flip status
      allow update: if request.resource.data.status == 'answered'
                    && request.resource.data.answer is string
                    && request.resource.data.answer.size() > 0;
      allow delete: if true;
    }
  }
}
